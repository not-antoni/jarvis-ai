# Required
DISCORD_TOKEN=
# For Render: Use MongoDB Atlas URI
# For Selfhost: Use local MongoDB (e.g., mongodb://localhost:27017/jarvis)
MONGO_URI_MAIN=
MONGO_URI_VAULT=
MASTER_KEY_BASE64=

# Deployment Mode: render, selfhost, or hybrid (auto-detect)
# - render: Uses RENDER_EXTERNAL_URL for Cloudflare DNS
# - selfhost: Uses PUBLIC_BASE_URL or auto-detected IP
# - hybrid: Auto-detects environment (recommended for VPS running Render-style)
DEPLOY_TARGET=hybrid
SELFHOST_MODE=false
PUBLIC_BASE_URL=
SITE_BASE_URL=https://jorvis.org
SITE_DOMAIN=jorvis.org
DISCORD_INVITE_URL=https://discord.com/invite/ksXzuBtmK5
BOT_INVITE_URL=
GA_MEASUREMENT_ID=
SERVER_BIND_HOST=
PORT=3000
ALLOWED_HOSTS=
CLOUDFLARE_ONLY=true
# Optional proxy/IP safety
# TRUSTED_PROXY_IPS supports comma/space-separated CIDRs for non-Cloudflare reverse proxies.
# CLOUDFLARE_IP_RANGES overrides reading /etc/nginx/cloudflare-ips.conf when set.
TRUSTED_PROXY_IPS=
CLOUDFLARE_IP_RANGES=
CLOUDFLARE_IPS_FILE=/etc/nginx/cloudflare-ips.conf
# Edge security guard (issues #262, #265, #266)
#  BLOCKED_ASNS    - comma-separated AS numbers (require Cloudflare transform rule
#                    that sets `cf-asn` so this is visible upstream)
#  BLOCKED_COUNTRIES - ISO 3166-1 alpha-2 codes ("ru,kp"); reads `cf-ipcountry`
#  IP_WHITELIST    - comma-separated CIDRs/IPs allowed to reach non-public routes
#  IP_WHITELIST_MODE - "soft" (default, only protects portal/api) or "strict" (all routes)
BLOCKED_ASNS=
BLOCKED_COUNTRIES=
IP_WHITELIST=
IP_WHITELIST_MODE=soft
# Max bytes for remote images fetched from user-supplied URLs (defaults to 10MB).
REMOTE_IMAGE_MAX_BYTES=
DISABLE_DISCORD=0
ALLOW_START_WITHOUT_DB=0
LOCAL_DB_MODE=0

# Optional Discord intents
DISCORD_ENABLE_MESSAGE_CONTENT=
DISCORD_ENABLE_PRESENCE_INTENT=

# Optional dashboard / monitoring
DASHBOARD_PASSWORD=
PASSWORD=
HEALTH_TOKEN=

# Optional webserver limits
JSON_BODY_LIMIT=
CORS_ALLOWED_ORIGINS=

# Optional AI providers
OPENROUTER_API_KEY=
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
# Google AI for Startups credit (#264). Same env var, two backends:
#   GOOGLE_TRIAL_BACKEND=gemini  (default) - Generative Language API key, same
#                                surface as GOOGLE_AI_API_KEY (use this with
#                                AIza... or AQ. tokens issued by AI Studio).
#   GOOGLE_TRIAL_BACKEND=vertex  - Vertex AI in Express Mode (REST). Required
#                                for trial keys that only work via Vertex.
#   GOOGLE_TRIAL_BACKEND=both    - register both transports; the failover
#                                loop benches whichever returns 401.
# `VERTEX_PROVIDER=true` is an alias for `GOOGLE_TRIAL_BACKEND=vertex`.
GOOGLE_TRIAL=
GOOGLE_TRIAL_BACKEND=gemini
# Vertex AI Express Mode region - leave blank/global unless your key is
# region-pinned. Common values: global, us-central1, europe-west1.
VERTEX_LOCATION=global
# Optional override for Vertex models when GOOGLE_TRIAL_BACKEND uses vertex.
# Defaults to gemini-2.5-flash (broadly available on Vertex Express Mode).
VERTEX_MODELS=
CEREBRAS_API_KEY=
SAMBANOVA_API_KEY=
MISTRAL_API_KEY=
OPENAI_API_KEY=
OPENAI_STT_MODEL=
OPENAI_STT_LANGUAGE=
VOICE_ACTIVE_SPEAKER_IDLE_MS=
VOICE_ACTIVE_SPEAKER_FOLLOWUP_MS=
VOICE_WAKEWORD_PROBE_MS=
AI_PROXY_ENABLED=
AI_PROXY_URLS=
AI_PROXY_TOKEN=
AI_PROXY_STRATEGY=
AI_PROXY_ALLOWED_HOSTS=
AI_PROXY_BYPASS_HOSTS=
AI_PROXY_DEBUG=
AI_PROXY_FALLBACK_DIRECT=
AI_PROXY_AUTO_PROVISION=
AI_PROXY_SAVE_TO_DB=
AI_MAX_OUTPUT_TOKENS=1024
AI_MAX_INPUT_CHARS=2000
AI_MAX_INPUT_TOKENS=1024
GOOGLE_AI_ENABLE_PREVIEW_MODELS=
AI_PROXY_WORKERS_COUNT=
AI_PROXY_WORKER_PREFIX=
AI_PROXY_SET_WORKER_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_WORKERS_SUBDOMAIN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMAIL=
CLOUDFLARE_GLOBAL_API_KEY=
CLOUDFLARE_ORIGIN_CA_API_KEY=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_WORKER_URL=

# Admin / Owner (REQUIRED - no hardcoded fallbacks)
ADMIN_USER_ID=
BOT_OWNER_ID=

# Command channel whitelist (comma-separated Discord channel IDs)
WHITELISTED_CHANNEL_IDS=

# Sentience (comma-separated guild IDs where advanced AI is enabled)
SENTIENCE_ENABLED=true
SENTIENCE_GUILDS=

# Music guild whitelist (comma-separated guild IDs)
MUSIC_GUILD_WHITELIST=

# Moderation guild IDs
MODERATION_GUILD_IDS=

# Easter egg ship pair (user IDs)
SHIP_EASTER_EGG_1=
SHIP_EASTER_EGG_2=

# Starkbucks (SBX) Virtual Economy
JARVIS_DOMAIN=

# Optional extras
BRAVE_API_KEY=
YOUTUBE_API_KEY=
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
SOUNDCLOUD_API_TIMEOUT_MS=8000
SOUNDCLOUD_TOKEN_REFRESH_SKEW_MS=60000
NEWS_API_KEY=

# Optional OAuth (moderator auth)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Optional webhooks
FORWARD_WEBHOOK=
DISCORD_WEBHOOK_PUBLIC_KEY=

# GitHub (for yt-dlp updates - increases rate limit)
GITHUB_TOKEN=

# yt-dlp / ffmpeg configuration
FFMPEG_PATH=
YTDLP_MAX_DURATION=900
YTDLP_MAX_FILESIZE_MB=50
YTDLP_FORMAT=
YTDLP_YOUTUBE_FORMAT=
YTDLP_EXTRA_CLIENTS=
YTDLP_EXTRACTOR_ARGS=
YTDLP_DISABLE_AUTO_UPDATE=0
MUSIC_FAST_START_MODE=1
MUSIC_STREAM_BUFFER_BYTES=2097152
MUSIC_PREBUFFER_BYTES=524288
MUSIC_PREBUFFER_TIMEOUT_MS=1500
MUSIC_DIRECT_STREAM_ENABLED=1
MUSIC_DIRECT_STREAM_SOURCES=youtube,soundcloud
MUSIC_YOUTUBE_DIRECT_STREAM_ENABLED=1
MUSIC_DIRECT_PREBUFFER_BYTES=196608
MUSIC_DIRECT_PREBUFFER_TIMEOUT_MS=9000
MUSIC_DIRECT_OPUS_BITRATE=160k
MUSIC_DIRECT_OPUS_COMPLEXITY=8
MUSIC_OUTPUT_HEADROOM_DB=4
MUSIC_OUTPUT_LIMITER_ENABLED=1
MUSIC_VOICE_READY_TIMEOUT_MS=30000
MUSIC_VOICE_JOIN_RETRIES=4
MUSIC_VOICE_JOIN_RETRY_DELAY_MS=1500
MUSIC_VOICE_RECONNECT_ATTEMPTS=10
MUSIC_VOICE_RECONNECT_DELAY_MS=1500
MUSIC_VOICE_ENSURE_READY_RETRIES=3

# YouTube cookies (for age-restricted content)
YT_COOKIES=

# Hugging Face
HF_TOKEN=

# Ollama API keys (for vision models)
OLLAMA_API_KEY=

# AI Gateway (Vercel)
AI_GATEWAY_API_KEY=

# NVIDIA NIM
NVIDIA_API_KEY=
NVIDIA_STT_URL=
NVIDIA_TTS_URL=
JARVIS_VOICE_REF=assets/voice/jarvis_reference.wav

# Logging
LOG_LEVEL=info
ENABLE_CONSOLE_LOGGING=true
ENABLE_FILE_LOGGING=true

# Top.gg bot list
TOPGG_TOKEN=

# SBX route admin secret (for website news posting)
SBX_NEWS_SECRET=

# =============================================================================
# WEB PORTAL (Discord OAuth2)
# =============================================================================

# Client ID & secret from https://discord.com/developers/applications
# Grab them under OAuth2 → "Copy" for the client id/secret.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Override the OAuth callback URL. Defaults to `${SITE_BASE_URL}/portal/callback`.
# Must exactly match one of the redirect URIs configured in the Discord app.
# PORTAL_CALLBACK_URL=

# Session TTL in milliseconds (default: 7 days).
# PORTAL_SESSION_TTL_MS=

# =============================================================================
# WEB SEARCH (Brave Search)
# =============================================================================

# Enables automatic prompt augmentation when the AI detects a time-sensitive
# query. Leave blank to disable web search entirely. (#268: there is no
# /search slash command anymore - the AI uses Brave internally.)
# Get a key: https://api.search.brave.com/app/dashboard
# Either variable name works - BRAVE_API_KEY is accepted as a shorter alias.
BRAVE_SEARCH_API_KEY=
# BRAVE_API_KEY=
# Set to false to disable auto-augmentation entirely.
WEB_SEARCH_AUTO=true
# Max ms to wait for Brave before falling back to the model's prior knowledge.
WEB_SEARCH_TIMEOUT_MS=3500
# Results included in the prompt block (1-5).
WEB_SEARCH_MAX_RESULTS=3
# SafeSearch filter - defaults to STRICT for both web and image (#262 feeds
# results into the system prompt; NSFW SERPs are a prompt-poisoning vector).
# Valid values: off | moderate | strict.
BRAVE_SAFESEARCH=strict
# Optional: separate filter for image search. Falls back to BRAVE_SAFESEARCH.
BRAVE_IMAGE_SAFESEARCH=strict

# =============================================================================
# AI PROVIDER COOLDOWNS
# =============================================================================

# How long (ms) to bench a Google credential group after daily-quota
# exhaustion ("Limit: 0" / "billing details" in the 429 body).
# Default: 2 hours. Lower values cause wasted probe requests that can
# themselves be counted against the quota.
# PERMANENT_QUOTA_BENCH_MS=7200000

# =============================================================================
# MODERATION - WARN / STRIKE THRESHOLDS
# =============================================================================

# Default escalation (relaxed). Override to taste; set WARN_TIER3_ACTION=none
# to disable the auto-kick tier entirely.
WARN_TIER1_COUNT=3
WARN_TIER1_TIMEOUT_MS=600000      # 10 minutes
WARN_TIER2_COUNT=5
WARN_TIER2_TIMEOUT_MS=3600000     # 1 hour
WARN_TIER3_COUNT=10
WARN_TIER3_ACTION=kick            # "kick" or "none"
WARN_WINDOW_MS=2592000000         # 30 days (counted for tiers 1 & 2)

# =============================================================================
# SELFHOST CONFIGURATION
# =============================================================================

# Node.js performance
UV_THREADPOOL_SIZE=16

# Voice/music transport now uses @discordjs/voice + yt-dlp directly.
# Keep Node >=22.12.0 to stay compatible with Discord DAVE requirements.

# PM2 app name (for health-check.sh)
PM2_APP_NAME=jarvis
