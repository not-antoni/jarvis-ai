# Required
DISCORD_TOKEN=
# For Render: Use MongoDB Atlas URI
# For Selfhost: Use local MongoDB (e.g., mongodb://localhost:27017/jarvis)
MONGO_URI_MAIN=
MONGO_URI_VAULT=
MASTER_KEY_BASE64=

# Deployment Mode: render, selfhost, or hybrid (auto-detect)
# - render: Uses RENDER_EXTERNAL_URL for Cloudflare DNS
# - selfhost: Uses PUBLIC_BASE_URL or auto-detected IP
# - hybrid: Auto-detects environment (recommended for VPS running Render-style)
DEPLOY_TARGET=hybrid
SELFHOST_MODE=false
PUBLIC_BASE_URL=
SITE_BASE_URL=https://jorvis.org
SITE_DOMAIN=jorvis.org
DISCORD_INVITE_URL=https://discord.com/invite/ksXzuBtmK5
BOT_INVITE_URL=
GA_MEASUREMENT_ID=
SERVER_BIND_HOST=
PORT=3000
ALLOWED_HOSTS=
CLOUDFLARE_ONLY=true
DISABLE_DISCORD=0
ALLOW_START_WITHOUT_DB=0
LOCAL_DB_MODE=0

# Optional Discord intents
DISCORD_ENABLE_MESSAGE_CONTENT=
DISCORD_ENABLE_PRESENCE_INTENT=

# Optional dashboard / monitoring
DASHBOARD_PASSWORD=
PASSWORD=
HEALTH_TOKEN=

# Optional webserver limits
JSON_BODY_LIMIT=
CORS_ALLOWED_ORIGINS=

# Optional AI providers
OPENROUTER_API_KEY=
GROQ_API_KEY=
GOOGLE_AI_API_KEY=
OPENAI_API_KEY=
LOCAL_EMBEDDING_URL=
AI_PROXY_ENABLED=
AI_PROXY_URLS=
AI_PROXY_TOKEN=
AI_PROXY_STRATEGY=
AI_PROXY_ALLOWED_HOSTS=
AI_PROXY_DEBUG=
AI_PROXY_FALLBACK_DIRECT=
AI_PROXY_AUTO_PROVISION=
AI_PROXY_SAVE_TO_DB=
AI_PROXY_WORKERS_COUNT=
AI_PROXY_WORKER_PREFIX=
AI_PROXY_SET_WORKER_TOKEN=
CLOUDFLARE_ACCOUNT_ID=
CLOUDFLARE_WORKERS_SUBDOMAIN=
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_EMAIL=
CLOUDFLARE_GLOBAL_API_KEY=
CLOUDFLARE_ORIGIN_CA_API_KEY=
CLOUDFLARE_ZONE_ID=
CLOUDFLARE_WORKER_URL=

# Admin / Owner (REQUIRED — no hardcoded fallbacks)
ADMIN_USER_ID=
BOT_OWNER_ID=

# Command channel whitelist (comma-separated Discord channel IDs)
WHITELISTED_CHANNEL_IDS=

# Sentience (comma-separated guild IDs where advanced AI is enabled)
SENTIENCE_ENABLED=true
SENTIENCE_GUILDS=

# Music guild whitelist (comma-separated guild IDs)
MUSIC_GUILD_WHITELIST=

# Server logging (guildId:channelId pairs, comma-separated)
LOG_CHANNELS=

# Meme sender target
MEME_GUILD_ID=
MEME_CHANNEL_ID=

# Error log channel
ERROR_LOG_CHANNEL_ID=

# Guild features (primary guild ID for anti-scam/alt detection)
GUILD_FEATURES_PRIMARY=
MODERATION_GUILD_IDS=

# TERF wiki guild lock
TERF_GUILD_ID=

# Easter egg ship pair (user IDs)
SHIP_EASTER_EGG_1=
SHIP_EASTER_EGG_2=

# Starkbucks (SBX) Virtual Economy
JARVIS_DOMAIN=

# Optional extras
BRAVE_API_KEY=
YOUTUBE_API_KEY=
SOUNDCLOUD_CLIENT_ID=
SOUNDCLOUD_CLIENT_SECRET=
SOUNDCLOUD_API_TIMEOUT_MS=8000
SOUNDCLOUD_TOKEN_REFRESH_SKEW_MS=60000
CRYPTO_API_KEY=
NEWS_API_KEY=
NINJA_API_KEY=
ALPHA_VANTAGE_API_KEY=
COINMARKETCAP_API_KEY=

# Optional OAuth (moderator auth)
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=

# Optional webhooks
FORWARD_WEBHOOK=
DISCORD_WEBHOOK_PUBLIC_KEY=

# GitHub (for yt-dlp updates - increases rate limit)
GITHUB_TOKEN=

# yt-dlp / ffmpeg configuration
FFMPEG_PATH=
YTDLP_MAX_DURATION=900
YTDLP_MAX_FILESIZE_MB=50
YTDLP_EXTRA_CLIENTS=
YTDLP_EXTRACTOR_ARGS=
YTDLP_DISABLE_AUTO_UPDATE=0
MUSIC_FAST_START_MODE=1
MUSIC_STREAM_BUFFER_BYTES=2097152
MUSIC_PREBUFFER_BYTES=524288
MUSIC_PREBUFFER_TIMEOUT_MS=1500
MUSIC_DIRECT_STREAM_ENABLED=1
MUSIC_DIRECT_STREAM_SOURCES=youtube,soundcloud
MUSIC_DIRECT_PREBUFFER_BYTES=196608
MUSIC_DIRECT_PREBUFFER_TIMEOUT_MS=9000
MUSIC_DIRECT_OPUS_BITRATE=160k
MUSIC_DIRECT_OPUS_COMPLEXITY=8

# YouTube cookies (for age-restricted content)
YT_COOKIES=

# Twitch integration
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# Hugging Face
HF_TOKEN=

# Ollama API keys (for vision models)
OLLAMA_API_KEY=
OLLAMA_API_KEY2=
OLLAMA_API_KEY3=
OLLAMA_API_KEY4=
OLLAMA_API_KEY5=
OLLAMA_API_KEY6=
OLLAMA_API_KEY7=
OLLAMA_API_KEY8=

# Mixtral / Cohere
MIXTRAL_API_KEY=
COHERE_API_KEY=

# AI Gateway (Vercel)
AI_GATEWAY_API_KEY=

# Dashboard session
DASHBOARD_SESSION_SECRET=

# Logging
LOG_LEVEL=info
ENABLE_CONSOLE_LOGGING=true
ENABLE_FILE_LOGGING=true

# Top.gg bot list
TOPGG_TOKEN=

# SBX route admin secret (for website news posting)
SBX_NEWS_SECRET=

# =============================================================================
# SELFHOST CONFIGURATION
# =============================================================================

# Session security (generate a separate key from MASTER_KEY)
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
USER_SESSION_SECRET=

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# MongoDB settings (for local MongoDB)
MONGO_POOL_SIZE=10

# Node.js performance
UV_THREADPOOL_SIZE=16

# Voice/music transport now uses @discordjs/voice + yt-dlp directly.
# Keep Node >=22.12.0 to stay compatible with Discord DAVE requirements.

# Health check notifications (optional Discord webhook for alerts)
DISCORD_HEALTH_WEBHOOK_URL=

# PM2 app name (for health-check.sh)
PM2_APP_NAME=jarvis
