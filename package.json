{
  "name": "jarvis-discord-bot",
  "version": "1.1.0",
  "description": "Jarvis - A sentient Discord bot with AI capabilities",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "verify": "node scripts/deploy.js",
    "provision:ai-proxies": "node scripts/provision-ai-proxies.js",
    "test": "node --test 'tests/**/*.test.js'",
    "test:coverage": "c8 --reporter=text --reporter=lcov --reporter=html --all --src src --exclude 'src/commands/music/**' --exclude 'src/services/handlers/**' node --test 'tests/**/*.test.js'",
    "setup:check": "node scripts/check-setup.js",
    "migrate": "node scripts/run-migrations.js",
    "migrate:local": "node scripts/migrate-to-local.js",
    "dump": "node scripts/nightly-dump.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\""
  },
  "keywords": [
    "discord",
    "bot",
    "ai",
    "jarvis"
  ],
  "author": "",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "eslint": "^10.2.1",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.8.3"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.64",
    "@ai-sdk/openai": "^3.0.53",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "@google-cloud/vertexai": "^1.12.0",
    "@google/generative-ai": "^0.24.1",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@snazzah/davey": "^0.1.11",
    "ai": "^6.0.168",
    "canvas": "^3.2.3",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "discord.js": "^14.26.3",
    "dotenv": "^17.4.2",
    "emoji-regex": "^10.6.0",
    "express": "^5.2.1",
    "express-rate-limit": "^7.4.0",
    "extract-zip": "^2.0.1",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.0.0",
    "googleapis": "^171.4.0",
    "helmet": "^8.0.0",
    "lru-cache": "^11.3.5",
    "mongodb": "^7.2.0",
    "node-cron": "^4.2.1",
    "openai": "^6.34.0",
    "opusscript": "^0.1.1",
    "puppeteer": "^24.42.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.5",
    "tar": "^7.5.13",
    "tweetnacl": "^1.0.3"
  },
  "overrides": {
    "undici": "^6.24.0",
    "yauzl": "^3.2.1"
  }
}
