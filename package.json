{
  "name": "jarvis-discord-bot",
  "version": "1.1.0",
  "description": "Jarvis - A sentient Discord bot with AI capabilities",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "verify": "node scripts/deploy.js",
    "provision:ai-proxies": "node scripts/provision-ai-proxies.js",
    "test": "node --test 'tests/**/*.test.js'",
    "setup:check": "node scripts/check-setup.js",
    "migrate": "node scripts/run-migrations.js",
    "migrate:local": "node scripts/migrate-to-local.js",
    "dump": "node scripts/nightly-dump.js",
    "lint": "eslint . --ext .js",
    "lint:fix": "eslint . --ext .js --fix",
    "format": "prettier --write \"**/*.js\"",
    "format:check": "prettier --check \"**/*.js\""
  },
  "keywords": [
    "discord",
    "bot",
    "ai",
    "jarvis"
  ],
  "author": "",
  "license": "GPL-3.0-only",
  "engines": {
    "node": ">=22.12.0"
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "eslint-plugin-import": "^2.29.1",
    "prettier": "^3.3.3"
  },
  "dependencies": {
    "@ai-sdk/google": "^3.0.58",
    "@ai-sdk/openai": "^3.0.50",
    "@discordjs/opus": "^0.10.0",
    "@discordjs/voice": "^0.19.0",
    "@google/generative-ai": "^0.24.1",
    "@grpc/grpc-js": "^1.14.3",
    "@grpc/proto-loader": "^0.8.0",
    "@snazzah/davey": "^0.1.9",
    "ai": "^6.0.146",
    "canvas": "^3.2.0",
    "cheerio": "^1.0.0-rc.12",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "discord.js": "^14.22.1",
    "dotenv": "^17.2.3",
    "emoji-regex": "^10.6.0",
    "express": "^4.18.2",
    "extract-zip": "^2.0.1",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.0.0",
    "googleapis": "^160.0.0",
    "helmet": "^8.0.0",
    "lru-cache": "^10.2.2",
    "mongodb": "^6.19.0",
    "node-cron": "^4.2.1",
    "node-fetch": "^2.6.7",
    "openai": "^5.20.1",
    "opusscript": "^0.1.1",
    "puppeteer": "^24.34.0",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
    "sharp": "^0.34.4",
    "tar": "^7.5.2",
    "tweetnacl": "^1.0.3"
  },
  "overrides": {
    "undici": "^6.24.0",
    "yauzl": "^3.2.1"
  }
}
